---
// Desktop nav: page links only — clean, not overcrowded
const pageLinks = [
  { href: '/services/ac',     ar: 'مكيفات', en: 'AC Repair'     },
  { href: '/services/fridge', ar: 'ثلاجات', en: 'Fridge Repair' },
  { href: '/services/washer', ar: 'غسالات', en: 'Washer Repair' },
  { href: '/about',           ar: 'من نحن', en: 'About Us'       },
];

// Mobile menu: page links + home-page anchor shortcuts
const mobileAnchors = [
  { href: '/#services', ar: 'خدماتنا',   en: 'Services'      },
  { href: '/#how',      ar: 'كيف نعمل',  en: 'How It Works'  },
  { href: '/#why',      ar: 'لماذا نحن', en: 'Why Us'         },
  { href: '/#contact',  ar: 'تواصل',     en: 'Contact'        },
];

const currentPath = Astro.url.pathname;
---

<header>
  <div class="wrap nav">

    <!-- Brand -->
    <a class="brand" href="/" aria-label="خط الوردة">
      <span class="mark">
        <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
          <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9"/>
          <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(72 12 12)"/>
          <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(144 12 12)"/>
          <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(216 12 12)"/>
          <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(288 12 12)"/>
          <circle cx="12" cy="12" r="2.2"/>
        </svg>
      </span>
      <span class="name">
        <b>خط الوردة</b>
        <span class="en">Khat Alwarda · Jazan</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links" aria-label="القائمة الرئيسية">
      {pageLinks.map(item => (
        <a
          href={item.href}
          data-en={item.en}
          class={currentPath.startsWith(item.href) ? 'active' : ''}
        >{item.ar}</a>
      ))}
    </nav>

    <!-- Desktop actions -->
    <div class="nav-actions">
      <button class="lang-toggle" id="langToggle" type="button" aria-label="Switch language">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="9"/>
          <path d="M3 12h18"/>
          <path d="M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"/>
        </svg>
        <span class="lt-label">EN</span>
      </button>

      <a class="nav-cta" href="https://wa.me/966552959806" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17">
          <path d="M17.5 14.4c-.3-.2-1.7-.8-2-.9-.3-.1-.5-.2-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3z"/>
          <path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-2.9.8.8-2.8-.2-.3a8.2 8.2 0 1 1 6.9 3.7z"/>
        </svg>
        <span data-en="WhatsApp">واتساب</span>
      </a>

      <!-- Hamburger (mobile only) -->
      <button class="nav-toggle" id="navToggle" type="button" aria-label="القائمة · Menu" aria-expanded="false" aria-controls="mobileMenu">
        <svg class="ic-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/>
        </svg>
        <svg class="ic-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M6 6l12 12"/><path d="M18 6L6 18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile slide-down menu -->
  <nav class="mobile-menu" id="mobileMenu" aria-label="القائمة المحمولة">
    <p class="mm-section-label" data-en="Pages">الصفحات</p>
    {pageLinks.map(item => (
      <a href={item.href} data-en={item.en}>{item.ar}</a>
    ))}
    <div class="mm-divider"></div>
    <p class="mm-section-label" data-en="On this page">في الصفحة</p>
    {mobileAnchors.map(item => (
      <a href={item.href} data-en={item.en}>{item.ar}</a>
    ))}
  </nav>

  <div class="menu-backdrop" id="menuBackdrop" aria-hidden="true"></div>
</header>

<style>
  .mm-section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--muted-2);
    text-transform: uppercase;
    padding: 10px 6px 4px;
  }
  .mm-divider {
    border-top: 1px solid rgba(255,255,255,0.07);
    margin: 8px 0;
  }
</style>
