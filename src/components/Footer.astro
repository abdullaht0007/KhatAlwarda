---
const serviceLinks = [
  { href: '/services/ac',     ar: 'صيانة مكيفات',  en: 'AC Repair'     },
  { href: '/services/fridge', ar: 'صيانة ثلاجات',  en: 'Fridge Repair' },
  { href: '/services/washer', ar: 'صيانة غسالات',  en: 'Washer Repair' },
];
const siteLinks = [
  { href: '/',        ar: 'الرئيسية',    en: 'Home'           },
  { href: '/about',   ar: 'من نحن',     en: 'About'          },
  { href: '/privacy', ar: 'سياسة الخصوصية', en: 'Privacy Policy' },
];
---

<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <a class="brand" href="/">
          <span class="mark">
            <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
              <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9"/>
              <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(72 12 12)"/>
              <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(144 12 12)"/>
              <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(216 12 12)"/>
              <path d="M12,12 C10.5,10 9,7 12,3 C15,7 13.5,10 12,12Z" opacity="0.9" transform="rotate(288 12 12)"/>
              <circle cx="12" cy="12" r="2.2"/>
            </svg>
          </span>
          <span class="name">
            <b>خط الوردة</b>
            <span class="en">Khat Alwarda</span>
          </span>
        </a>
        <p class="foot-desc" data-en="Trusted appliance repair across Jazan — AC, fridge and washing machine specialists.">
          صيانة موثوقة للمكيفات والثلاجات والغسالات في جازان. فنيون متخصصون بضمان على الإصلاح.
        </p>
      </div>

      <div class="foot-col">
        <h4 data-en="Services">الخدمات</h4>
        {serviceLinks.map(l => (
          <a href={l.href} data-en={l.en}>{l.ar}</a>
        ))}
      </div>

      <div class="foot-col">
        <h4 data-en="Navigation">التنقل</h4>
        {siteLinks.map(l => (
          <a href={l.href} data-en={l.en}>{l.ar}</a>
        ))}
      </div>

      <div class="foot-col">
        <h4 data-en="Contact">تواصل معنا</h4>
        <a href="tel:+966552959806" dir="ltr">+966 55 295 9806</a>
        <a href="https://wa.me/966552959806" target="_blank" rel="noopener" data-en="WhatsApp Us">راسلنا واتساب</a>
        <p class="foot-hours" data-en="Sat–Thu: 08:00–22:00">السبت – الخميس: ٨ص – ١٠م</p>
      </div>
    </div>

    <div class="foot-bottom">
      <div class="copy">
        <span data-en="AC, fridge &amp; washing-machine repair · Jazan">صيانة المكيفات والثلاجات والغسالات · جازان</span>
        <span class="en"> © 2026 KhatAlwarda. All rights reserved.</span>
      </div>
      <div class="foot-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span data-en="Jazan, Saudi Arabia">جازان، المملكة العربية السعودية</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .foot-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .foot-desc {
    font-size: 14px; color: var(--muted); margin-top: 16px; line-height: 1.7; max-width: 260px;
  }
  .foot-col h4 {
    font-size: 13px; font-weight: 700; letter-spacing: 0.06em; color: var(--muted-2);
    text-transform: uppercase; margin-bottom: 18px;
  }
  .foot-col a {
    display: block; font-size: 14.5px; color: var(--muted); margin-bottom: 10px;
    transition: color .15s;
  }
  .foot-col a:hover { color: var(--ink); }
  .foot-hours { font-size: 13px; color: var(--muted-2); margin-top: 8px; }
  .foot-bottom {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px; padding-top: 28px;
  }
  .copy { color: var(--muted-2); font-size: 13px; }
  .foot-badge {
    display: flex; align-items: center; gap: 6px;
    color: var(--muted-2); font-size: 13px;
  }
  @media (max-width: 900px) {
    .foot-top { grid-template-columns: 1fr 1fr; }
    .foot-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 560px) {
    .foot-top { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
