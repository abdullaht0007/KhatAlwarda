---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — الصفحة غير موجودة | خط الوردة"
  description="الصفحة التي تبحث عنها غير موجودة. عد إلى الرئيسية أو تواصل معنا عبر واتساب."
>

<section class="not-found-section">
  <div class="wrap not-found-wrap">
    <div class="not-found-code reveal">404</div>
    <h1 class="not-found-title reveal" data-en="Page not found">الصفحة غير موجودة</h1>
    <p class="not-found-desc reveal" data-en="The link may be broken or the page may have been moved. Head back home or reach us on WhatsApp.">
      الرابط قد يكون خاطئاً أو الصفحة نُقلت. عد إلى الرئيسية أو تواصل معنا مباشرة.
    </p>
    <div class="not-found-actions reveal">
      <a class="btn btn-primary" href="/">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M9 21V12h6v9"/></svg>
        <span data-en="Back to Home">العودة للرئيسية</span>
      </a>
      <a class="btn btn-wa" href="https://wa.me/966552959806?text=السلام%20عليكم،%20أرغب%20بالتواصل%20معكم" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.7-.8-2-.9-.3-.1-.5-.2-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3z"/><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span data-en="WhatsApp Us">واتساب</span>
      </a>
    </div>
  </div>
</section>

<style>
.not-found-section {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
}
.not-found-wrap {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}
.not-found-code {
  font-size: clamp(96px, 18vw, 180px);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -6px;
  background: linear-gradient(135deg, var(--blue), var(--teal));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 0.9;
}
.not-found-title {
  font-size: clamp(24px, 4vw, 36px);
  font-weight: 800;
  color: var(--ink);
}
.not-found-desc {
  max-width: 480px;
  color: var(--muted);
  font-size: 16px;
  line-height: 1.75;
}
.not-found-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 8px;
}
</style>

</BaseLayout>
