---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import heroImg      from '../assets/images/hero.jpg';
import svcAcImg     from '../assets/images/svc-ac.jpg';
import svcFridgeImg from '../assets/images/svc-fridge.jpg';
import svcWasherImg from '../assets/images/svc-washer.jpg';

const preloadedHero = await getImage({ src: heroImg, width: 900, height: 1125, format: 'webp' });

const structuredData = {
  "@context": "https://schema.org",
  "@type": "HVACBusiness",
  "name": "خط الوردة · KhatAlwarda",
  "description": "صيانة المكيفات والثلاجات والغسالات في جازان — زيارة منزلية أو ورشة، بقطع أصلية وضمان.",
  "url": "https://khatalwarda.sa",
  "areaServed": { "@type": "City", "name": "Jazan" },
  "address": { "@type": "PostalAddress", "addressLocality": "Jazan", "addressCountry": "SA" },
  "telephone": "+966552959806",
  "hasMap": "https://maps.app.goo.gl/NUky35knUYGC7Np67",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "47",
    "bestRating": "5",
    "worstRating": "1"
  },
  "priceRange": "$$",
  "openingHours": "Sa-Th 08:00-22:00",
  "makesOffer": [
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "صيانة مكيفات · AC repair" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "صيانة ثلاجات · Fridge repair" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "صيانة غسالات · Washer repair" } }
  ]
};
---

<BaseLayout
  title="خط الوردة | KhatAlwarda — صيانة المكيفات والثلاجات والغسالات في جازان"
  description="خط الوردة — صيانة احترافية للمكيفات والثلاجات والغسالات في جازان. زيارة منزلية في نفس اليوم، قطع غيار أصلية وضمان على العمل."
  structuredData={structuredData}
>
  <link slot="head" rel="preload" as="image" href={preloadedHero.src} type="image/webp" fetchpriority="high" />

<!-- ===================== HERO ===================== -->
<section class="hero">
  <div class="wrap hero-inner">
    <div class="hero-copy reveal">
      <span class="kicker">
        <span class="dot"></span>
        <span data-en="Home &amp; workshop appliance repair · Jazan">صيانة منزلية وورشة متخصصة · جازان</span>
      </span>
      <h1 data-en="Is your appliance <span class='grad'>broken?</span>">
        هل جهازك <span class="grad">تعطّل؟</span>
      </h1>

      <div class="hero-tw-wrap" aria-live="polite" aria-atomic="true">
        <span class="hero-tw-word" id="heroTw"></span><span class="tw-cursor" aria-hidden="true">|</span>
      </div>

      <p class="lead" data-en="Specialist technicians for AC, fridge and washing-machine repair — same-day home visits or workshop service. Reliable work, backed by warranty.">
        فنيون متخصصون لصيانة المكيفات والثلاجات والغسالات — زيارة منزلية في نفس اليوم أو إصلاح داخل الورشة. خدمة موثوقة بضمان.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="https://wa.me/966552959806?text=السلام%20عليكم،%20أرغب%20بحجز%20موعد%20صيانة" target="_blank" rel="noopener">
          <span data-en="Book Now">احجز الآن</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l-7 7 7 7"/></svg>
        </a>
        <a class="btn btn-ghost" href="tel:+966552959806">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.1a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z"/></svg>
          <span data-en="Call Us">اتصل بنا</span>
        </a>
      </div>
      <div class="hero-trust">
        <div class="ti">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          <span data-en="Same-day visits">زيارة في نفس اليوم</span>
        </div>
        <div class="ti">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 7v5c0 4.5 3.2 7.8 8 9 4.8-1.2 8-4.5 8-9V7l-8-5z"/></svg>
          <span data-en="1-month warranty">ضمان شهر</span>
        </div>
        <div class="ti">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          <span data-en="Certified technicians">فنيون معتمدون</span>
        </div>
      </div>
    </div>

    <div class="hero-visual glass reveal">
      <Image src={heroImg} width={900} height={1125} alt="فني خط الوردة" style="display:block;width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:16px;" loading="eager" />
      <div class="float-card">
        <span class="ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
        <span>
          <b data-en="1,200+ successful repairs">+1200 إصلاح ناجح</b>
          <span>Trusted in Jazan</span>
        </span>
      </div>
    </div>
  </div>
</section>

<!-- ===================== SERVICES ===================== -->
<section id="services" class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="Our Services">خدماتنا</span></span>
      <h2 data-en="We fix everything that cools and cleans">نصلح كل ما يبرّد ويغسل</h2>
      <p data-en="Professional repair with genuine parts — at your home or inside our fully-equipped workshop.">صيانة احترافية بقطع غيار أصلية. سواء في منزلك أو داخل ورشتنا المجهّزة.</p>
    </div>
    <div class="cards-3">
      <article class="svc glass reveal">
        <div class="svc-img-wrap"><Image src={svcAcImg} width={740} height={316} alt="صيانة مكيف" class="svc-img" loading="lazy" /></div>
        <span class="ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="9" rx="2"/><path d="M5 9h14"/><path d="M6 16.5c1.5 0 1.5 1.5 3 1.5"/><path d="M12 16.5c1.5 0 1.5 1.5 3 1.5"/><path d="M16 17c.8-.5 1.2-1 2-1"/></svg>
        </span>
        <h3 data-en="Air Conditioning">مكيفات</h3>
        <div class="en-name">Air Conditioning</div>
        <p data-en="Cleaning, freon recharge, weak-cooling fixes, water leaks, and service for window &amp; split units.">تنظيف، شحن فريون، إصلاح التبريد الضعيف، تسريب المياه، وصيانة المكيفات الشباك والسبليت.</p>
        <div class="tags">
          <span class="tag" data-en="Freon">شحن فريون</span>
          <span class="tag" data-en="Cleaning">تنظيف</span>
          <span class="tag" data-en="Install">تركيب</span>
        </div>
        <a class="svc-link" href="/services/ac">
          <span data-en="Learn more">تفاصيل الخدمة</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l-7 7 7 7"/></svg>
        </a>
      </article>

      <article class="svc glass reveal">
        <div class="svc-img-wrap"><Image src={svcFridgeImg} width={740} height={316} alt="صيانة ثلاجة" class="svc-img" loading="lazy" /></div>
        <span class="ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M5 9h14"/><path d="M8 5v2"/><path d="M8 12v3"/></svg>
        </span>
        <h3 data-en="Refrigerators">ثلاجات</h3>
        <div class="en-name">Refrigerators</div>
        <p data-en="Weak cooling, compressor &amp; thermostat replacement, abnormal freezing, and gas leaks.">معالجة ضعف التبريد، تغيير الكمبروسر والثرموستات، تجمّد غير طبيعي، وتسريب الغاز.</p>
        <div class="tags">
          <span class="tag" data-en="Compressor">كمبروسر</span>
          <span class="tag" data-en="Cooling">تبريد</span>
          <span class="tag" data-en="Thermostat">ثرموستات</span>
        </div>
        <a class="svc-link" href="/services/fridge">
          <span data-en="Learn more">تفاصيل الخدمة</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l-7 7 7 7"/></svg>
        </a>
      </article>

      <article class="svc glass reveal">
        <div class="svc-img-wrap"><Image src={svcWasherImg} width={740} height={316} alt="صيانة غسالة" class="svc-img" loading="lazy" /></div>
        <span class="ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4.5"/><circle cx="12" cy="14" r="1.6"/><path d="M7 5.5h.01"/><path d="M10 5.5h.01"/></svg>
        </span>
        <h3 data-en="Washing Machines">غسالات</h3>
        <div class="en-name">Washing Machines</div>
        <p data-en="No-spin or drainage faults, water leaks, control-board issues, and heavy vibration.">إصلاح عدم الدوران أو التصريف، تسريب الماء، أعطال لوحة التحكم، واهتزاز عالٍ.</p>
        <div class="tags">
          <span class="tag" data-en="Drainage">تصريف</span>
          <span class="tag" data-en="Control board">لوحة تحكم</span>
          <span class="tag" data-en="Leaks">تسريب</span>
        </div>
        <a class="svc-link" href="/services/washer">
          <span data-en="Learn more">تفاصيل الخدمة</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l-7 7 7 7"/></svg>
        </a>
      </article>
    </div>
  </div>
</section>

<!-- ===================== HOW IT WORKS ===================== -->
<section id="how" class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="How We Work">كيف نعمل</span></span>
      <h2 data-en="Three simple steps">ثلاث خطوات بسيطة</h2>
    </div>
    <div class="steps">
      <div class="step glass reveal">
        <span class="num">01</span>
        <h3 data-en="Contact Us">اتصل بنا</h3>
        <div class="en-name">Contact Us</div>
        <p data-en="Reach us on WhatsApp or by phone and describe the problem and the appliance.">تواصل عبر الواتساب أو الهاتف، وصف لنا المشكلة ونوع الجهاز.</p>
        <span class="connector"></span>
      </div>
      <div class="step glass reveal">
        <span class="num">02</span>
        <h3 data-en="We Visit You">نزور موقعك</h3>
        <div class="en-name">We Visit You</div>
        <p data-en="A specialist technician arrives at a time that suits you, or we collect the unit for the workshop.">يصلك فني متخصص في الموعد المناسب لك، أو نستلم الجهاز للورشة.</p>
        <span class="connector"></span>
      </div>
      <div class="step glass reveal">
        <span class="num">03</span>
        <h3 data-en="We Fix It">نصلح الجهاز</h3>
        <div class="en-name">We Fix It</div>
        <p data-en="Fast repair with genuine parts and a clear warranty on the work performed.">إصلاح سريع بقطع أصلية وضمان واضح على العمل المنفّذ.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===================== WHY / STATS ===================== -->
<section id="why" class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="Why Choose KhatAlwarda">لماذا خط الوردة</span></span>
      <h2 data-en="Experience you can trust">خبرة تثق بها</h2>
    </div>
    <div class="stats">
      <div class="stat glass reveal">
        <div class="stat-ic-wrap">
          <svg class="stat-ring" viewBox="0 0 68 68" aria-hidden="true"><circle class="stat-ring-bg" cx="34" cy="34" r="31"/><circle class="stat-ring-fill" cx="34" cy="34" r="31"/></svg>
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
        </div>
        <div class="val" data-count="12" data-suffix="+">0</div>
        <div class="lbl" data-en="Years Experience">سنة خبرة</div>
        <div class="en-lbl">Years Experience</div>
      </div>
      <div class="stat glass reveal">
        <div class="stat-ic-wrap">
          <svg class="stat-ring" viewBox="0 0 68 68" aria-hidden="true"><circle class="stat-ring-bg" cx="34" cy="34" r="31"/><circle class="stat-ring-fill" cx="34" cy="34" r="31"/></svg>
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.7 0L3 12.3a4 4 0 0 0 5.7 5.7l1-1"/><path d="M9.3 17.7a4 4 0 0 0 5.7 0l6-6a4 4 0 0 0-5.7-5.7l-1 1"/></svg></span>
        </div>
        <div class="val" data-count="1200" data-suffix="+">0</div>
        <div class="lbl" data-en="Repairs Done">جهاز تم إصلاحه</div>
        <div class="en-lbl">Repairs Done</div>
      </div>
      <div class="stat glass reveal">
        <div class="stat-ic-wrap">
          <svg class="stat-ring" viewBox="0 0 68 68" aria-hidden="true"><circle class="stat-ring-bg" cx="34" cy="34" r="31"/><circle class="stat-ring-fill" cx="34" cy="34" r="31"/></svg>
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
        </div>
        <div class="val" data-count="950" data-suffix="+">0</div>
        <div class="lbl" data-en="Happy Customers">عميل سعيد</div>
        <div class="en-lbl">Happy Customers</div>
      </div>
      <div class="stat glass reveal">
        <div class="stat-ic-wrap">
          <svg class="stat-ring" viewBox="0 0 68 68" aria-hidden="true"><circle class="stat-ring-bg" cx="34" cy="34" r="31"/><circle class="stat-ring-fill" cx="34" cy="34" r="31"/></svg>
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 7v5c0 4.5 3.2 7.8 8 9 4.8-1.2 8-4.5 8-9V7l-8-5z"/><path d="M9.5 12.5l1.8 1.8 3.5-3.8"/></svg></span>
        </div>
        <div class="val" data-count="1" data-suffix="">0</div>
        <div class="lbl" data-en="Months Warranty">شهر ضمان</div>
        <div class="en-lbl">Month Warranty</div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== REVIEWS ===================== -->
<section class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="Customer Reviews">آراء العملاء</span></span>
      <h2 data-en="Trusted by families across Jazan">موثوقون من عائلات جازان</h2>
    </div>
    <div class="reviews-cta glass reveal">
      <div class="reviews-badge">
        <svg class="google-g" viewBox="0 0 24 24" aria-label="Google">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="reviews-score-wrap">
          <span class="reviews-score">4.8</span>
          <div class="reviews-stars" aria-label="4.8 out of 5 stars">
            {Array(5).fill(0).map(() => (
              <svg viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <span class="reviews-count" data-en="on Google Maps">على خرائط جوجل</span>
        </div>
      </div>
      <p class="reviews-desc" data-en="Read what real customers say about our service — or share your own experience after your repair.">
        اقرأ آراء العملاء الحقيقيين عن خدمتنا — أو شارك تجربتك بعد الإصلاح.
      </p>
      <div class="reviews-actions">
        <a class="btn btn-primary" href="https://maps.app.goo.gl/NUky35knUYGC7Np67" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span data-en="Read Reviews on Google">اقرأ التقييمات على جوجل</span>
        </a>
        <a class="btn btn-ghost" href="https://maps.app.goo.gl/NUky35knUYGC7Np67" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
          <span data-en="Write a Review">اكتب تقييماً</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===================== LOCATION ===================== -->
<section id="location" class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="Find Us">موقعنا</span></span>
      <h2 data-en="Visit our workshop in Jazan">زورونا في ورشتنا بجازان</h2>
    </div>
    <div class="map-wrap reveal">
      <iframe
        class="map-frame"
        src="https://maps.google.com/maps?q=16.897798,42.556324&z=15&output=embed"
        width="100%"
        height="420"
        style="border:0;border-radius:16px;display:block;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="موقع خط الوردة على الخريطة"
      ></iframe>
      <div class="map-actions">
        <a
          class="btn btn-primary"
          href="https://maps.app.goo.gl/NUky35knUYGC7Np67"
          target="_blank"
          rel="noopener"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span data-en="Open in Google Maps">افتح في خرائط جوجل</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===================== CTA ===================== -->
<section id="contact" class="sec-pad">
  <div class="wrap">
    <div class="cta glass reveal">
      <h2 data-en="Your appliance deserves professional service">جهازك يستاهل صيانة محترفة</h2>
