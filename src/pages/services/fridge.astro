---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import fridgeBannerImg from '../../assets/images/fridge-banner.jpg';

const waMsg = encodeURIComponent('السلام عليكم، أرغب بحجز موعد صيانة ثلاجة');

const problems = [
  { ar: 'ضعف التبريد أو انعدامه', en: 'Weak or no cooling', desc_ar: 'فحص الغاز والكمبروسر ودوائر التبريد.', desc_en: 'Check gas, compressor, and cooling circuits.' },
  { ar: 'استبدال الكمبروسر', en: 'Compressor replacement', desc_ar: 'كمبروسرات أصلية لجميع الماركات مع ضمان.', desc_en: 'Genuine compressors for all brands with warranty.' },
  { ar: 'تجمّد غير طبيعي', en: 'Abnormal freezing', desc_ar: 'إصلاح الثرموستات وسخان الإذابة ومستشعرات الحرارة.', desc_en: 'Fix thermostat, defrost heater, and temperature sensors.' },
  { ar: 'تسريب الغاز', en: 'Gas leak', desc_ar: 'كشف التسريب وإصلاحه وإعادة شحن الغاز بالكمية الصحيحة.', desc_en: 'Detect and fix the leak, then recharge gas to correct level.' },
  { ar: 'الثلاجة لا تعمل', en: 'Unit not working', desc_ar: 'فحص كامل: كهرباء، لوحة إلكترونية، ريليه، ومكثف.', desc_en: 'Full check: power, control board, relay, and capacitor.' },
  { ar: 'ضوضاء وأصوات عالية', en: 'Loud noise', desc_ar: 'فحص مروحة المكثف والكمبروسر وعزل الاهتزازات.', desc_en: 'Check condenser fan, compressor, and vibration isolation.' },
  { ar: 'استبدال الثرموستات', en: 'Thermostat replacement', desc_ar: 'استبدال الثرموستات بقطعة أصلية مع ضبط درجة الحرارة.', desc_en: 'Replace thermostat with genuine part and calibrate temperature.' },
  { ar: 'تسريب المياه الداخلي', en: 'Internal water leak', desc_ar: 'تنظيف أنبوب التصريف وإصلاح مصدر التسريب.', desc_en: 'Clean drain tube and fix the source of the leak.' },
];

const brands = ['Samsung · سامسونج', 'LG', 'Zanussi · زانوسي', 'Haier · هايير', 'Whirlpool', 'Hisense · هايسنس', 'Toshiba · توشيبا', 'Beko', 'Sharp · شارب', 'Hitachi'];

const faq = [
  { q_ar: 'هل تصيّنون الثلاجة في المنزل؟', q_en: 'Do you repair fridges at home?', a_ar: 'نعم، معظم الأعطال تُصلح في موقعك. بعض الأعطال المعقدة قد تتطلب نقل الثلاجة للورشة مع ترتيب مسبق.', a_en: 'Yes, most faults are fixed on-site. Complex repairs may require bringing the unit to our workshop by prior arrangement.' },
  { q_ar: 'كم تكلف صيانة الثلاجة؟', q_en: 'How much does fridge repair cost?', a_ar: 'التكلفة تعتمد على نوع العطل والقطعة المطلوبة. نوفر تشخيصاً مجانياً ونعطيك السعر قبل البدء بالإصلاح.', a_en: 'Cost depends on the fault and required part. We offer free diagnosis and quote you before starting any repair.' },
  { q_ar: 'هل الكمبروسر المستبدل أصلي؟', q_en: 'Is the replacement compressor genuine?', a_ar: 'نعم، نستخدم كمبروسرات أصلية فقط مع شهادة المصنع ونوفر ضمان شهر على القطعة والعمل.', a_en: 'Yes, we use only genuine compressors with manufacturer certification and provide 1-month warranty.' },
  { q_ar: 'كم تستغرق صيانة الثلاجة؟', q_en: 'How long does fridge repair take?', a_ar: 'الأعطال البسيطة من ١ إلى ٢ ساعة. استبدال الكمبروسر عادةً من ٢ إلى ٤ ساعات.', a_en: 'Simple faults: 1–2 hours. Compressor replacement: usually 2–4 hours.' },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://khatalwarda.sa" },
      { "@type": "ListItem", "position": 2, "name": "صيانة ثلاجات", "item": "https://khatalwarda.sa/services/fridge" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "صيانة ثلاجات جازان · Fridge Repair Jazan",
    "provider": { "@type": "HVACBusiness", "name": "خط الوردة · KhatAlwarda" },
    "areaServed": { "@type": "City", "name": "Jazan" },
    "description": "صيانة ثلاجات احترافية في جازان — استبدال الكمبروسر، إصلاح التبريد، الثرموستات وتسريب الغاز.",
    "url": "https://khatalwarda.sa/services/fridge"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map(item => ({
      "@type": "Question",
      "name": item.q_en,
      "acceptedAnswer": { "@type": "Answer", "text": item.a_en }
    }))
  }
];
---

<BaseLayout
  title="صيانة ثلاجات جازان | Fridge Repair Jazan — خط الوردة KhatAlwarda"
  description="صيانة ثلاجات احترافية في جازان — استبدال الكمبروسر، إصلاح ضعف التبريد، الثرموستات وتسريب الغاز. زيارة منزلية وضمان شهر."
  structuredData={structuredData}
>

<!-- Page Hero -->
<section class="page-hero">
  <div class="wrap">
    <div class="breadcrumb">
      <a href="/" data-en="Home">الرئيسية</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      <span data-en="Fridge Repair">صيانة ثلاجات</span>
    </div>
    <span class="kicker"><span class="dot"></span> <span data-en="Fridge Repair · Jazan">صيانة ثلاجات · جازان</span></span>
    <h1 data-en="Expert <span class='grad'>Fridge Repair</span> in Jazan">صيانة <span class="grad">ثلاجات</span> احترافية في جازان</h1>
    <p data-en="Compressor replacement, weak cooling, gas leaks, thermostat fixes and full diagnostics — for all brands. Same-day visits available.">
      استبدال الكمبروسر، ضعف التبريد، تسريب الغاز، إصلاح الثرموستات وتشخيص كامل — لجميع الماركات. زيارة منزلية في نفس اليوم.
    </p>
    <div class="hero-actions">
      <a class="btn btn-wa" href={`https://wa.me/966552959806?text=${waMsg}`} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.7-.8-2-.9-.3-.1-.5-.2-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3z"/><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span data-en="Book Fridge Repair">احجز صيانة الثلاجة</span>
      </a>
      <a class="btn btn-ghost" href="tel:+966552959806">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.1a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z"/></svg>
        <span data-en="Call Now">اتصل الآن</span>
      </a>
    </div>
  </div>
</section>

<!-- Service photo banner -->
<section class="sec-pad" style="padding-top:0">
  <div class="wrap">
    <Image src={fridgeBannerImg} width={1200} height={675} alt="صيانة ثلاجة احترافية في جازان" style="display:block;width:100%;height:auto;aspect-ratio:16/9;object-fit:cover;border-radius:16px;" loading="lazy" />
  </div>
</section>

<!-- Problems -->
<section class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="What We Fix">ما نصلحه</span></span>
      <h2 data-en="All fridge problems, solved">كل أعطال الثلاجات، محلولة</h2>
    </div>
    <div class="problems-grid reveal">
      {problems.map(p => (
        <div class="problem-item">
          <div class="pi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div>
            <h4 data-en={p.en}>{p.ar}</h4>
            <p data-en={p.desc_en}>{p.desc_ar}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Brands -->
<section class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="Brands We Service">الماركات التي نخدمها</span></span>
      <h2 data-en="All major brands">جميع الماركات الكبرى</h2>
    </div>
    <div class="brands-row reveal">
      {brands.map(b => <span class="brand-chip">{b}</span>)}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker"><span class="dot"></span> <span data-en="FAQ">الأسئلة الشائعة</span></span>
      <h2 data-en="Common questions about fridge repair">أسئلة شائعة عن صيانة الثلاجات</h2>
    </div>
    <div class="faq-list reveal">
      {faq.map(item => (
        <div class="faq-item">
          <button class="faq-q" type="button">
            <span data-en={item.q_en}>{item.q_ar}</span>
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
          </button>
          <div class="faq-a">
            <span data-en={item.a_en}>{item.a_ar}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="sec-pad">
  <div class="wrap">
    <div class="cta glass reveal">
      <h2 data-en="Your fridge fixed — fast and guaranteed">ثلاجتك تُصلح — بسرعة وضمان</h2>
      <div class="cta-actions">
        <a class="btn btn-wa" href={`https://wa.me/966552959806?text=${waMsg}`} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.7-.8-2-.9-.3-.1-.5-.2-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3z"/><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
          <span data-en="Book via WhatsApp">احجز عبر واتساب</span>
        </a>
        <a class="btn btn-ghost" href="tel:+966552959806">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.1a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z"/></svg>
          <span data-en="Call Directly">اتصل مباشرة</span>
        </a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
